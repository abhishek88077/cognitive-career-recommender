# Environment configuration for Cognitive Career Recommendation System
# Copy this file to .env and update the values as needed

# Flask Configuration
SECRET_KEY=cognitive-ai-career-system-2024-secure-key
DEBUG=True

# Database Configuration (Optional - for future expansion) 
DATABASE_URL=sqlite:///career_system.db

# AI/ML Configuration
MODEL_PATH=models/
DATA_PATH=data/

# File Upload Settings
MAX_CONTENT_LENGTH=16777216  # 16MB in bytes
UPLOAD_FOLDER=data/uploads

# Email (SMTP) Configuration
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# External API Keys (if needed)
# OPENAI_API_KEY=your_openai_key_here
# KAGGLE_API_KEY=your_kaggle_key_here

# Adzuna (Real-Time Jobs)
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key
ADZUNA_COUNTRY=in
ADZUNA_RESULTS_PER_PAGE=20

# Logging Configuration
LOG_LEVEL=INFO

# Application Settings
MAX_RECOMMENDATIONS=10
REASONING_THRESHOLD=0.75
EXPLANATION_DEPTH=3